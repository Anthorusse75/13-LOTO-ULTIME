# ── LOTO ULTIME — Docker environment ──
# Copy this file to .env before running docker-compose up

# Backend
SECRET_KEY=change-me-to-a-random-string-of-at-least-32-chars
APP_ENV=production

# Traefik
DOMAIN=loto.example.com
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# Grafana (monitoring profile only)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
