# EditorConfig — https://editorconfig.org
# Cohérence de formatage entre tous les éditeurs/IDE

root = true

# ── Défaut global ──
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ── Python ──
[*.py]
indent_size = 4
max_line_length = 100

# ── JavaScript / TypeScript / JSX / TSX ──
[*.{js,jsx,ts,tsx}]
indent_size = 2

# ── JSON / YAML / TOML ──
[*.{json,yaml,yml,toml}]
indent_size = 2

# ── HTML / CSS ──
[*.{html,css,scss}]
indent_size = 2

# ── Markdown ──
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# ── Makefile (tabs obligatoires) ──
[Makefile]
indent_style = tab

# ── Shell scripts ──
[*.{sh,bash}]
indent_size = 2

# ── Docker ──
[Dockerfile*]
indent_size = 4
