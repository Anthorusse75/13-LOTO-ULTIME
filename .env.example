# ============================================
# LOTO ULTIME — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ============================================

# ── Application ──
APP_NAME=loto-ultime
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# ── Sécurité ──
# Clé secrète pour signer les JWT (min 32 caractères)
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE-ME-generate-a-real-secret-key-min-32-chars
# Ancienne clé pour rotation gracieuse (optionnel)
# PREVIOUS_SECRET_KEY=

# Mot de passe initial de l'administrateur (à changer au premier login)
ADMIN_INITIAL_PASSWORD=<CHANGEZ-MOI>
ADMIN_EMAIL=admin@loto-ultime.local

# ── Base de données ──
# SQLite (développement local)
DATABASE_URL=sqlite+aiosqlite:///./loto_ultime.db

# PostgreSQL (Docker / production) — utilisé par docker-compose.yml
# DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── PostgreSQL Docker (utilisé par docker-compose.yml) ──
POSTGRES_DB=loto_ultime
POSTGRES_USER=loto
POSTGRES_PASSWORD=<CHANGEZ-MOI>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000

# ── CORS ──
# Origines autorisées (JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── JWT ──
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Pour RS256 (asymétrique, multi-service) — décommenter et adapter
# JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY_PATH=/path/to/private.pem
# JWT_PUBLIC_KEY_PATH=/path/to/public.pem
# Ou directement le contenu PEM :
# JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----...
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----...

# ── Scraper FDJ ──
FDJ_BASE_URL=https://www.fdj.fr
EUROMILLIONS_BASE_URL=https://www.fdj.fr

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=60

# ── Logging ──
LOG_LEVEL=INFO
LOG_JSON=false

# ── Scheduler ──
SCHEDULER_ENABLED=false

# ── LLM (Groq — gratuit, optionnel) ──
# Créer un compte sur https://console.groq.com et obtenir une clé API
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Docker Compose ──
# Port d'accès au frontend (défaut : 3080)
FRONTEND_PORT=3080

# ── Monitoring (profil monitoring) ──
GRAFANA_USER=admin
GRAFANA_PASSWORD=<CHANGEZ-MOI>
