# ============================================
# LOTO ULTIME — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ============================================

# ── Application ──
APP_NAME=loto-ultime
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# ── Sécurité ──
# Clé secrète pour signer les JWT (min 32 caractères)
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE-ME-generate-a-real-secret-key-min-32-chars

# Mot de passe initial de l'administrateur (à changer au premier login)
ADMIN_INITIAL_PASSWORD=ChangeMe123!
ADMIN_EMAIL=admin@loto-ultime.local

# ── Base de données ──
# SQLite (développement)
DATABASE_URL=sqlite+aiosqlite:///./loto_ultime.db

# PostgreSQL (production) — décommenter et adapter
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/loto_ultime

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ── CORS ──
# Origines autorisées (JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── JWT ──
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Logging ──
LOG_LEVEL=INFO
LOG_JSON=false

# ── Scheduler ──
SCHEDULER_ENABLED=true
