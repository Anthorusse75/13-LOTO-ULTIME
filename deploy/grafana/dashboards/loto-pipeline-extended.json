{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Pipeline Steps Status (last run)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "loto_last_pipeline_run_timestamp_seconds",
          "legendFormat": "Last pipeline run",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "Scraper Fetches / hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "increase(loto_scraper_fetches_total[1h])",
          "legendFormat": "{{game}} ({{status}})"
        }
      ]
    },
    {
      "title": "Draws Saved / hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "increase(loto_scraper_draws_saved_total[1h])",
          "legendFormat": "{{game}}"
        }
      ]
    },
    {
      "title": "Engine Compute Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(loto_engine_compute_duration_seconds_bucket[5m]))",
          "legendFormat": "{{engine}} — {{game}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Engine Errors / hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "increase(loto_engine_errors_total[1h])",
          "legendFormat": "{{engine}} — {{game}}"
        }
      ]
    },
    {
      "title": "Budget Optimizations / hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "increase(loto_budget_optimizations_total[1h])",
          "legendFormat": "{{game}} ({{objective}})"
        }
      ]
    },
    {
      "title": "Comparisons / hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "increase(loto_comparisons_total[1h])",
          "legendFormat": "{{game}}"
        }
      ]
    },
    {
      "title": "Exports / hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "increase(loto_exports_total[1h])",
          "legendFormat": "{{format}}"
        }
      ]
    }
  ],
