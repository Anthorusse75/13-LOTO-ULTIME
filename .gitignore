# ============================================
# LOTO ULTIME — .gitignore
# Python (Backend) + React/Node (Frontend)
# ============================================

# ──────────────── Python ────────────────

# Bytecode / cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
wheels/

# Virtual environments
.venv/
venv/
ENV/

# pytest / coverage
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# mypy / ruff / type checkers
.mypy_cache/
.ruff_cache/
.pytype/

# Jupyter
.ipynb_checkpoints/

# ──────────────── Node / React ────────────────

# Dependencies
node_modules/

# Build output
frontend/dist/
frontend/build/

# Vite
*.local

# ──────────────── Environnement ────────────────

# Variables d'environnement (contiennent des secrets)
.env
.env.local
.env.production
.env.*.local

# NE PAS ignorer .env.example (il est versionné)
!.env.example

# ──────────────── Base de données ────────────────

*.db
*.sqlite
*.sqlite3

# Alembic (ne pas ignorer les migrations elles-mêmes)
# mais ignorer les fichiers temporaires
*.db-journal
*.db-wal
*.db-shm

# ──────────────── IDE / Éditeurs ────────────────

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# JetBrains (PyCharm, WebStorm)
.idea/

# Vim
*.swp
*.swo
*~

# ──────────────── OS ────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.directory

# ──────────────── Docker ────────────────

# Ne pas ignorer Dockerfile/docker-compose (versionnés)
# Ignorer les volumes et données Docker locales
docker-data/

# ──────────────── Logs ────────────────

logs/
*.log

# ──────────────── Divers ────────────────

# Archives
*.tar.gz
*.zip
*.rar

# Temporary files
tmp/
temp/
